exports[`'buildLinuxPodmanCommand' > should generate basic command with minimal configuration 1`] = `
"sudo systemctl enable --now podman.socket

sudo podman volume create portainer_agent_data

sudo podman run -d \\
  -v /run/podman/podman.sock:/var/run/docker.sock \\
  -v /var/lib/containers/storage/volumes:/var/lib/docker/volumes \\
  -v /:/host \\
  -v portainer_agent_data:/data \\
  --restart always \\
  --privileged \\
  -e EDGE=1 \\
  -e EDGE_ID=test-edge-id \\
  -e EDGE_KEY=test-edge-key \\
  -e EDGE_INSECURE_POLL=0 \\
  -e AGENT_SECRET=test-secret \\
  --name portainer_edge_agent \\
  portainer/agent:2.19.0
  "
`;

